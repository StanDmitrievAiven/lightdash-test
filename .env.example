# Copy to .env (or set as Variables in the Aiven Apps console) and fill in.
# Do NOT commit a real .env — it's gitignored.

# === Required ===

# Aiven for PostgreSQL service URI. MUST include sslmode=require.
# Grab from Aiven Console -> Services -> <your-pg> -> Connection information -> "Service URI".
PGCONNECTIONURI=postgres://avnadmin:CHANGE_ME@<host>:<port>/defaultdb?sslmode=require

# Long random string. Generate with:  openssl rand -hex 32
# Keep STABLE across deploys — encrypted state in PG becomes unrecoverable if it changes.
LIGHTDASH_SECRET=change_me_to_a_long_random_string

# Public https URL where Lightdash will be reachable.
SITE_URL=https://lightdash.<your-aiven-app>.aivencloud.app


# === Recommended for production ===

SECURE_COOKIES=true
TRUST_PROXY=true
SCHEDULER_ENABLED=true
LIGHTDASH_LOG_LEVEL=info


# === Optional (advanced features) ===

# Headless browser sidecar for chart screenshots / PDF exports / scheduled deliveries with images.
# HEADLESS_BROWSER_HOST=browser
# HEADLESS_BROWSER_PORT=3001

# S3-compatible object storage for query results + scheduled delivery files.
# S3_ENDPOINT=
# S3_BUCKET=
# S3_REGION=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_FORCE_PATH_STYLE=true   # set to true for MinIO / non-AWS S3

# Email (SMTP) for invitations and scheduled deliveries.
# EMAIL_SMTP_HOST=
# EMAIL_SMTP_PORT=587
# EMAIL_SMTP_SECURE=true
# EMAIL_SMTP_USER=
# EMAIL_SMTP_PASSWORD=
# EMAIL_SMTP_SENDER_EMAIL=
# EMAIL_SMTP_SENDER_NAME=Lightdash

# Slack integration for sharing & deliveries.
# SLACK_TOKEN=
# SLACK_SIGNING_SECRET=
# SLACK_APP_TOKEN=
